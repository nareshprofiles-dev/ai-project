[
  {
    "id": 0,
    "start": 28.56,
    "end": 29.98,
    "text": "కలేజ్ లైఫ్"
  },
  {
    "id": 1,
    "start": 33.86,
    "end": 38.02,
    "text": "మరి కోందరు మనం విళుతున చేడుదారిని మనంచి మంచి వాయపు"
  },
  {
    "id": 2,
    "start": 38.02,
    "end": 38.7,
    "text": "తేస్కల్లారు."
  },
  {
    "id": 3,
    "start": 49.8,
    "end": 53.46,
    "text": "ఫ్రేండ్స్ తరవాత ఇకట్ చాలా మందిన టాచ్చేసేదు"
  },
  {
    "id": 4,
    "start": 53.46,
    "end": 58.28,
    "text": "టినేజ్"
  },
  {
    "id": 5,
    "start": 58.28,
    "end": 68.68,
    "text": "లావ"
  },
  {
    "id": 6,
    "start": 69.62,
    "end": 73.16,
    "text": "మరి కొందరు జూన్యర్లో వచ్చాక వాళను చూస్తు హిరోల్"
  },
  {
    "id": 7,
    "start": 73.16,
    "end": 77.54,
    "text": "హిపోతార్ ఏది ఏమైనా ప్రతివాడికి కాలేజ్ లాఇఫండే బీటుఫుల్"
  },
  {
    "id": 8,
    "start": 77.54,
    "end": 82.6,
    "text": "సిన్మానే ప్రతి వాడు తన ఫ్రేమ్ లో హిరోనే మనందరి"
  },
  {
    "id": 9,
    "start": 82.6,
    "end": 86.6,
    "text": "జివితాల్లో స్కూలిం తరవత మేన్ ఫేజస్ అంటే కాలేజ్ ప్రేమా"
  },
  {
    "id": 10,
    "start": 86.6,
    "end": 92.82,
    "text": "కిరీర్ పెల్లి ఆపాయ్ పిలలు ఇమద్యలో కుద్ధికోద్ధికా కాలంతో"
  },
  {
    "id": 11,
    "start": 92.82,
    "end": 97.58,
    "text": "పాటు అడోవ్తు వచ్చే మెచ్యూరిటి ఇల్లాంటి కి ఫేజిస్ని"
  },
  {
    "id": 12,
    "start": 97.58,
    "end": 101.08,
    "text": "తచ్చేస్తు యుత్తు ఉండే కంఫ్యుంస్లో చాలా విష్యాలికు"
  },
  {
    "id": 13,
    "start": 101.08,
    "end": 104.74,
    "text": "క్లారిటీ ఇస్తునే మనందరిని మదురా నియాపకాల్లోకు"
  },
  {
    "id": 14,
    "start": 104.74,
    "end": 108.78,
    "text": "తిస్కేడ్లే మంచి ప్రేత్నం చేసిన మలైయాలం లోని ప్రదేయం"
  },
  {
    "id": 15,
    "start": 108.78,
    "end": 112.4,
    "text": "సినిమా దర్శకుడునే అవినందిస్తు మరోక్క మంచ్చి విడో తో"
  },
  {
    "id": 16,
    "start": 112.4,
    "end": 113.26,
    "text": "మరలా గలుగ్దాం."
  },
  {
    "id": 17,
    "start": 114.04,
    "end": 114.74,
    "text": "తేంక్ యూ."
  },
  {
    "id": 18,
    "start": 115.16,
    "end": 116.0,
    "text": "సినింగ్ అఫ్."
  }
]